{
  "name": "Vacation Rental Marketplace",
  "description": "A full-featured vacation rental platform for guests and hosts",
  "repository": "https://github.com/yourusername/rental-platform",
  "keywords": ["node", "express", "react", "mongodb", "rental", "booking"],
  "image": "heroku/nodejs",
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ],
  "env": {
    "NODE_ENV": {
      "description": "Node environment",
      "value": "production"
    },
    "JWT_SECRET": {
      "description": "Secret key for JWT token generation",
      "generator": "secret"
    },
    "JWT_REFRESH_SECRET": {
      "description": "Secret key for refresh token generation",
      "generator": "secret"
    },
    "MONGODB_URI": {
      "description": "MongoDB connection string",
      "required": true
    },
    "CLIENT_URL": {
      "description": "Frontend application URL",
      "required": true
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "free"
    }
  },
  "addons": [
    {
      "plan": "mongolab:sandbox"
    }
  ]
}